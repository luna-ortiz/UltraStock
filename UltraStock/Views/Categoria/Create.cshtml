@model UltraStock.Models.Categoria
@{
    ViewData["Title"] = "Nueva Categoría";
}

<div class="d-flex align-items-center mb-4 gap-3">
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">← Volver</a>
    <h3 class="fw-bold mb-0">🏷️ Nueva Categoría</h3>
</div>

<div class="card border-0 shadow-sm rounded-4" style="max-width:500px;">
    <div class="card-body p-4">
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            <div class="mb-3">
                <label asp-for="Nombre" class="form-label fw-semibold">Nombre</label>
                <input asp-for="Nombre" class="form-control" placeholder="Nombre de la categoría" />
                <span asp-validation-for="Nombre" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Descripcion" class="form-label fw-semibold">Descripción</label>
                <textarea asp-for="Descripcion" class="form-control" rows="3"></textarea>
                <span asp-validation-for="Descripcion" class="text-danger small"></span>
            </div>
            <div class="mb-4">
                <label asp-for="Estado" class="form-label fw-semibold">Estado</label>
                <select asp-for="Estado" class="form-select">
                    <option value="Activo">Activo</option>
                    <option value="Inactivo">Inactivo</option>
                </select>
            </div>
            <button type="submit" class="btn btn-warning px-4">Guardar Categoría</button>
        </form>
    </div>
</div>
@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

}
