@model List<UltraStock.Models.Categoria>

<h2 class="mb-3">Lista de Categorias</h2>

@if (Context.Session.GetString("Rol") == "Administrador" || Context.Session.GetString("Rol") == "EncargadoAlmacen")
{
    <a class="btn btn-success mb-3" href="/Categoria/Create">+ Nueva Categoria</a>
}

<table class="table">
    <thead class="table-dark">
        <tr>
            <th>Nombre</th>
            <th>Descripcion</th>
            <th>Estado</th>
            @if (Context.Session.GetString("Rol") == "Administrador" || Context.Session.GetString("Rol") == "EncargadoAlmacen")
            {
                <th>Acciones</th>
            }
        </tr>
    </thead>

    <tbody>
        @foreach (var cat in Model)
        {
            <tr>
                <td>@cat.Nombre</td>
                <td>@cat.Descripcion</td>
                <td>
                    @if (string.IsNullOrEmpty(cat.Nombre))
                    {
                        <span class="text-danger" href="/Categoria/Edit/@cat.Id">Sin nombre</span>
                    }
                    else
                    {
                        <span class="text-success" href="/Categoria/Delete/@cat.Id">Activa</span>
                    }
                </td>

                @if (Context.Session.GetString("Rol") == "Administrador" || Context.Session.GetString("Rol") == "EncargadoAlmacen")
                {
                    <td>
                        <a class="btn btn-warning btn-sm"
                           href="/Categoria/Edit/@cat.Id">Editar</a>

                        @if (Context.Session.GetString("Rol") == "Administrador")
                        {
                            <a class="btn btn-danger btn-sm"
                               href="/Categoria/Delete/@cat.Id">Eliminar</a>
                        }
                    </td>
                }

            </tr>
        }
    </tbody>
</table>
