<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - UltraStock</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        body { background-color: #f8f9fa; }
        .navbar-brand { font-weight: 700; font-size: 1.4rem; color: #1d4ed8 !important; }
        .sidebar { min-height: calc(100vh - 56px); background: #1e293b; }
        .sidebar .nav-link { color: #94a3b8; padding: 10px 16px; border-radius: 6px; margin: 2px 8px; }
        .sidebar .nav-link:hover, .sidebar .nav-link.active { color: #fff; background: #1d4ed8; }
        .sidebar .nav-link .icon { margin-right: 8px; }
        .badge-rol { font-size: 0.7rem; }
        .alert-dismissible { border-radius: 8px; }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-dark" style="background:#1e293b;">
            <div class="container-fluid">
                <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                    📦 UltraStock
                </a>
                <div class="d-flex align-items-center gap-2 ms-auto">
                    @if (Context.Session.GetString("Usuario") != null)
                    {
                        <span class="text-white-50 small">
                            👤 @Context.Session.GetString("Usuario")
                            <span class="badge bg-primary ms-1 badge-rol">@Context.Session.GetString("Rol")</span>
                        </span>
                        <a class="btn btn-sm btn-outline-danger ms-2" asp-controller="Login" asp-action="Logout">
                            Cerrar sesión
                        </a>
                    }
                    else
                    {
                        <a class="btn btn-sm btn-primary" asp-controller="Login" asp-action="Index">Login</a>
                    }
                </div>
            </div>
        </nav>
    </header>

    <div class="container-fluid">
        <div class="row">
            @if (Context.Session.GetString("Usuario") != null)
            {
                <div class="col-md-2 col-lg-2 sidebar p-0 d-none d-md-block">
                    <nav class="py-3">
                        <ul class="nav flex-column">
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Home" asp-action="Index">
                                    <span class="icon">🏠</span> Inicio
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Producto" asp-action="Index">
                                    <span class="icon">📦</span> Productos
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Categoria" asp-action="Index">
                                    <span class="icon">🏷️</span> Categorías
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Proveedor" asp-action="Index">
                                    <span class="icon">🏭</span> Proveedores
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Movimiento" asp-action="Index">
                                    <span class="icon">🔄</span> Movimientos
                                </a>
                            </li>
                            @if (Context.Session.GetString("Rol") == "Administrador")
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Usuario" asp-action="Index">
                                        <span class="icon">👥</span> Usuarios
                                    </a>
                                </li>
                            }
                        </ul>
                    </nav>
                </div>
                <div class="col-md-10 col-lg-10 py-4">
                    @if (TempData["Exito"] != null)
                    {
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            ✅ @TempData["Exito"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }
                    @if (TempData["Error"] != null)
                    {
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            ❌ @TempData["Error"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }
                    @RenderBody()
                </div>
            }
            else
            {
                <div class="col-12">
                    @RenderBody()
                </div>
            }
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
