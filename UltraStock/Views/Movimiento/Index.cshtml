@model IEnumerable<UltraStock.Models.MovimientoInventario>
@{
    ViewData["Title"] = "Movimientos de Inventario";
    var rol = Context.Session.GetString("Rol");
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="fw-bold">🔄 Movimientos de Inventario</h3>
    @if (rol == "Administrador" || rol == "EncargadoAlmacen" || rol == "Auxiliar")
    {
        <a asp-action="Create" class="btn btn-success rounded-pill px-4">+ Registrar Movimiento</a>
    }
</div>

<div class="card border-0 shadow-sm rounded-4">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-dark">
                <tr>
                    <th>Fecha</th>
                    <th>Producto</th>
                    <th>Tipo</th>
                    <th>Cantidad</th>
                    <th>Observación</th>
                    @if (rol == "Administrador")
                    {
                        <th>Acciones</th>
                    }
                </tr>
            </thead>
            <tbody>
                @foreach (var m in Model)
                {
                    <tr>
                        <td>@m.Fecha.ToString("dd/MM/yyyy HH:mm")</td>
                        <td class="fw-semibold">@m.Producto?.Nombre</td>
                        <td>
                            <span class="badge @(m.TipoMovimiento == "Entrada" ? "bg-success" : "bg-danger")">
                                @(m.TipoMovimiento == "Entrada" ? "📥 Entrada" : "📤 Salida")
                            </span>
                        </td>
                        <td>@m.Cantidad</td>
                        <td class="text-muted small">@m.Observacion</td>
                        @if (rol == "Administrador")
                        {
                            <td>
                                <a asp-action="Delete" asp-route-id="@m.Id"
                                       class="btn btn-sm btn-outline-danger"
                                       onclick="return confirm('¿Eliminar este movimiento? El stock será revertido.')">
                                    Eliminar
                                </a>
                            </td>
                        }
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr><td colspan="6" class="text-center text-muted py-4">No hay movimientos registrados.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
