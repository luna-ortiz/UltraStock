@model UltraStock.Models.MovimientoInventario
@{
    ViewData["Title"] = "Registrar Movimiento";
}

<div class="d-flex align-items-center mb-4 gap-3">
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">← Volver</a>
    <h3 class="fw-bold mb-0">🔄 Registrar Movimiento de Inventario</h3>
</div>

<div class="card border-0 shadow-sm rounded-4" style="max-width:600px;">
    <div class="card-body p-4">
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            <div class="mb-3">
                <label asp-for="ProductoId" class="form-label fw-semibold">Producto</label>
                <select asp-for="ProductoId" class="form-select" required>
                    <option value="">-- Seleccione un producto --</option>
                    @foreach (var prod in ViewBag.Productos as List<UltraStock.Models.Producto>)
                    {
                        <option value="@prod.Id">@prod.Nombre (Stock: @prod.Stock)</option>
                    }
                </select>
                <span asp-validation-for="ProductoId" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="TipoMovimiento" class="form-label fw-semibold">Tipo de Movimiento</label>
                <select asp-for="TipoMovimiento" class="form-select" required>
                    <option value="">-- Seleccione --</option>
                    <option value="Entrada">📥 Entrada</option>
                    <option value="Salida">📤 Salida</option>
                </select>
                <span asp-validation-for="TipoMovimiento" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Cantidad" class="form-label fw-semibold">Cantidad</label>
                <input asp-for="Cantidad" type="number" min="1" class="form-control" placeholder="Cantidad de unidades" />
                <span asp-validation-for="Cantidad" class="text-danger small"></span>
            </div>
            <div class="mb-4">
                <label asp-for="Observacion" class="form-label fw-semibold">Observación (opcional)</label>
                <textarea asp-for="Observacion" class="form-control" rows="3" placeholder="Detalles del movimiento..."></textarea>
                <span asp-validation-for="Observacion" class="text-danger small"></span>
            </div>
            <button type="submit" class="btn btn-success px-4">Registrar Movimiento</button>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

}
