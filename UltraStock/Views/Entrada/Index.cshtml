@model List<UltraStock.Models.Producto>

<h2 class="mb-4">Entrada de Inventario</h2>

<a class="btn btn-secondary mb-3" href="/Movimiento">Volver a Movimientos</a>
<a class="btn btn-primary mb-3" href="/Entrada/Carrito">Ver carrito de entrada</a>

<div class="container mt-4">
    @if (TempData["Mensaje"] != null)
    {
        <div class="alert alert-success">
            @TempData["Mensaje"]
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">
            @TempData["Error"]
        </div>
    }

    <div class="row">
        @foreach (var item in Model)
        {
            <div class="col-md-3 mb-4">

                <div class="card h-100 shadow">

                    <img src="@item.ImagenUrl"
                         class="card-img-top"
                         style="height:200px; object-fit:cover;" />

                    <div class="card-body">

                        <h5 class="card-title">@item.Nombre</h5>

                        <p class="card-text">
                            Precio: $@item.Precio <br />
                            Stock actual: @item.Stock <br />
                            Categoria: @item.Categoria?.Nombre
                        </p>

                        <hr>

                        @* En entrada no se valida stock, se puede ingresar cualquier cantidad *@
                        <form asp-action="AgregarCarrito" method="post">
                            <input type="hidden" name="id" value="@item.Id" />
                            <input type="number"
                                   name="cantidad"
                                   value="1"
                                   min="1"
                                   class="form-control mb-2" />
                            <button class="btn btn-success w-100">
                                Agregar a entrada
                            </button>
                        </form>

                    </div>
                </div>
            </div>
        }
    </div>
</div>
