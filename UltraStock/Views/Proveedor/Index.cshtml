@model IEnumerable<UltraStock.Models.Proveedor>
@{
    ViewData["Title"] = "Proveedores";
    var rol = Context.Session.GetString("Rol");
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="fw-bold">🏭 Proveedores</h3>
    @if (rol == "Administrador" || rol == "EncargadoAlmacen")
    {
        <a asp-action="Create" class="btn btn-primary rounded-pill px-4">+ Nuevo Proveedor</a>
    }
</div>

<div class="card border-0 shadow-sm rounded-4">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-dark">
                <tr>
                    <th>Nombre</th>
                    <th>Teléfono</th>
                    <th>Email</th>
                    <th>Dirección</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in Model)
                {
                    <tr>
                        <td class="fw-semibold">@p.Nombre</td>
                        <td>@p.Telefono</td>
                        <td>@p.Email</td>
                        <td>@p.Direccion</td>
                        <td>
                            @if (rol == "Administrador" || rol == "EncargadoAlmacen")
                            {
                                <a asp-action="Edit" asp-route-id="@p.Id" class="btn btn-sm btn-outline-primary">Editar</a>
                            }
                            @if (rol == "Administrador")
                            {
                                <a asp-action="Delete" asp-route-id="@p.Id"
                                   class="btn btn-sm btn-outline-danger ms-1"
                                   onclick="return confirm('¿Eliminar proveedor @p.Nombre?')">Eliminar</a>
                            }
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr><td colspan="5" class="text-center text-muted py-4">No hay proveedores registrados.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
