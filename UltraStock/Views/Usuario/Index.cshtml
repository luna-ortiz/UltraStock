@model List<UltraStock.Models.Usuario>

<h2>Lista de Usuario</h2>

@if (Context.Session.GetString("Rol") == "Administrador")
{
    <a class="btn btn-success mb-3" href="/Usuario/Create">+ Nuevo Usuario</a>
}

<table class="table table-striped table-bordered">
    <thead class="table-dark">
        <tr>
            <th>Nombre</th>
            <th>Correo</th>
            <th>Rol</th>
            <th>Celular</th>
            @if (Context.Session.GetString("Rol") == "Administrador")
            {
                <th>Acciones</th>
            }

        </tr>
    </thead>

    <tbody>
        @foreach (var user in Model)
        {
            <tr>
                <td>@user.Nombre</td>
                <td>@user.Correo</td>
                <td>@user.Rol</td>
                <td>@user.celular</td>

                @if (Context.Session.GetString("Rol") == "Administrador")
                {
                    <td>
                        <a class="btn btn-warning btn-sm"
                           href="/Usuario/Edit/@user.Id">Editar</a>

                        <a class="btn btn-danger btn-sm"
                           href="/Usuario/Delete/@user.Id">Eliminar</a>

                    </td>
                }
            </tr>
        }
    </tbody>
</table>
