@model IEnumerable<UltraStock.Models.Usuario>
@{
    ViewData["Title"] = "Usuarios";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="fw-bold">👥 Usuarios del Sistema</h3>
    <a asp-action="Create" class="btn btn-danger rounded-pill px-4">+ Nuevo Usuario</a>
</div>

<div class="card border-0 shadow-sm rounded-4">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-dark">
                <tr>
                    <th>Nombre</th>
                    <th>Correo</th>
                    <th>Rol</th>
                    <th>Celular</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var u in Model)
                {
                    <tr>
                        <td class="fw-semibold">@u.Nombre</td>
                        <td>@u.Correo</td>
                        <td>
                            @{
                                var badgeColor = u.Rol switch
                                {
                                    "Administrador" => "bg-danger",
                                    "EncargadoAlmacen" => "bg-primary",
                                    "Supervisor" => "bg-info",
                                    "Auxiliar" => "bg-secondary",
                                    "Gerente" => "bg-success",
                                    _ => "bg-dark"
                                };
                            }
                            <span class="badge @badgeColor">@u.Rol</span>
                        </td>
                        <td>@u.celular</td>
                        <td>
                            <a asp-action="Edit" asp-route-id="@u.Id" class="btn btn-sm btn-outline-primary">Editar</a>
                            <a asp-action="Delete" asp-route-id="@u.Id"
                               class="btn btn-sm btn-outline-danger ms-1"
                               onclick="return confirm('¿Eliminar el usuario @u.Nombre?')">Eliminar</a>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr><td colspan="5" class="text-center text-muted py-4">No hay usuarios registrados.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
    