@model UltraStock.Models.Usuario

<h2>Crear Usuario</h2>

<form asp-action="Create" method="post">

    <div asp-validation-summary="All" class="text-danger"></div>

    <div class="mb-3">
        <label>Nombre</label>
        <input asp-for="Nombre" class="form-control" />
        <span asp-validation-for="Nombre" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label>Correo</label>
        <input asp-for="Correo" class="form-control" />
        <span asp-validation-for="Correo" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label>Rol</label>
        <select asp-for="Rol" class="form-control">
            <option value="">Seleccione un rol</option>
            <option value="Administrador">Administrador</option>
            <option value="EncargadoAlmacen">Encargado de Almacén</option>
            <option value="Supervisor">Supervisor</option>
            <option value="Auxiliar">Auxiliar</option>
            <option value="Gerente">Gerente</option>
        </select>
        <span asp-validation-for="Rol" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label>Celular</label>
        <input asp-for="celular" class="form-control" />
        <span asp-validation-for="celular" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label>Clave</label>
        <input asp-for="Clave" type="password" class="form-control" />
        <span asp-validation-for="Clave" class="text-danger"></span>
    </div>

    <hr>
    <button type="submit" class="btn btn-success">Guardar</button>
    <a href="/Usuario" class="btn btn-secondary">Volver</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
