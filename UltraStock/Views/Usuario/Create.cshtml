@model UltraStock.Models.Usuario
@{
    ViewData["Title"] = "Nuevo Usuario";
}

<div class="d-flex align-items-center mb-4 gap-3">
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">← Volver</a>
    <h3 class="fw-bold mb-0">👤 Nuevo Usuario</h3>
</div>

<div class="card border-0 shadow-sm rounded-4" style="max-width:550px;">
    <div class="card-body p-4">
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            <div class="mb-3">
                <label asp-for="Nombre" class="form-label fw-semibold">Nombre completo</label>
                <input asp-for="Nombre" class="form-control" placeholder="Nombre del usuario" />
                <span asp-validation-for="Nombre" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Correo" class="form-label fw-semibold">Correo electrónico</label>
                <input asp-for="Correo" type="email" class="form-control" placeholder="usuario@empresa.com" />
                <span asp-validation-for="Correo" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="celular" class="form-label fw-semibold">Celular</label>
                <input asp-for="celular" class="form-control" placeholder="3001234567" maxlength="10" />
                <span asp-validation-for="celular" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Rol" class="form-label fw-semibold">Rol</label>
                <select asp-for="Rol" class="form-select" required>
                    <option value="">-- Seleccione un rol --</option>
                    @foreach (var r in ViewBag.Roles as List<string>)
                    {
                        <option value="@r">@r</option>
                    }
                </select>
                <span asp-validation-for="Rol" class="text-danger small"></span>
            </div>
            <div class="mb-4">
                <label asp-for="Clave" class="form-label fw-semibold">Contraseña</label>
                <input asp-for="Clave" type="password" class="form-control" placeholder="Mínimo 4 caracteres" />
                <span asp-validation-for="Clave" class="text-danger small"></span>
            </div>
            <button type="submit" class="btn btn-danger px-4">Crear Usuario</button>
        </form>
    </div>
</div>
@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

}
