@model UltraStock.Models.Producto

<div class="container mt-4">

    <h2>Editar Producto</h2>

    <form asp-action="Edit" method="post" enctype="multipart/form-data">

        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <input type="hidden" asp-for="Id" />

        <div class="mb-3">
            <label>Nombre</label>
            <input asp-for="Nombre" class="form-control" />
            <span asp-validation-for="Nombre" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label>Descripción</label>
            <textarea asp-for="Descripcion" class="form-control"></textarea>
            <span asp-validation-for="Descripcion" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label>Precio</label>
            <input asp-for="Precio" class="form-control" />
            <span asp-validation-for="Precio" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label>Stock</label>
            <input asp-for="Stock" class="form-control" />
            <span asp-validation-for="Stock" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label>Categoría</label>

            <select asp-for="CategoriaId" class="form-control">
                @foreach (var cat in ViewBag.Categorias)
                {
                    <option value="@cat.Id">@cat.Nombre</option>
                }
            </select>
            <span asp-validation-for="CategoriaId" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label>Proveedor</label>

            <select asp-for="ProveedorId" class="form-control">
                @foreach (var proveedor in ViewBag.Proveedores)
                {
                    <option value="@proveedor.Id">@proveedor.Nombre</option>
                }
            </select>
            <span asp-validation-for="ProveedorId" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label>Imagen actual</label><br />
            <img src="@(string.IsNullOrWhiteSpace(Model.ImagenUrl) ? "/images/OIP.webp" : Model.ImagenUrl)" width="150" class="mb-2" />
        </div>

        <div class="mb-3">
            <label>Nueva Imagen (Opcional)</label>
            <input type="file" name="imagen" class="form-control" />
        </div>

        <button class="btn btn-primary">Actualizar</button>
        <a href="/Producto" class="btn btn-secondary">Volver</a>
    </form>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
