@model UltraStock.Models.Producto
@{
    ViewData["Title"] = "Editar Producto";
}

<div class="d-flex align-items-center mb-4 gap-3">
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">← Volver</a>
    <h3 class="fw-bold mb-0">✏️ Editar Producto</h3>
</div>

<div class="card border-0 shadow-sm rounded-4" style="max-width:650px;">
    <div class="card-body p-4">
        <form asp-action="Edit" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <input asp-for="Id" type="hidden" />
            <div class="row">
                <div class="col-md-8 mb-3">
                    <label asp-for="Nombre" class="form-label fw-semibold">Nombre del Producto</label>
                    <input asp-for="Nombre" class="form-control" />
                    <span asp-validation-for="Nombre" class="text-danger small"></span>
                </div>
                <div class="col-md-4 mb-3">
                    <label asp-for="Stock" class="form-label fw-semibold">Stock</label>
                    <input asp-for="Stock" type="number" min="0" class="form-control" />
                    <span asp-validation-for="Stock" class="text-danger small"></span>
                </div>
            </div>
            <div class="mb-3">
                <label asp-for="Descripcion" class="form-label fw-semibold">Descripción</label>
                <textarea asp-for="Descripcion" class="form-control" rows="2"></textarea>
                <span asp-validation-for="Descripcion" class="text-danger small"></span>
            </div>
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Precio" class="form-label fw-semibold">Precio ($)</label>
                    <input asp-for="Precio" type="number" step="0.01" min="0" class="form-control" />
                    <span asp-validation-for="Precio" class="text-danger small"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="CategoriaId" class="form-label fw-semibold">Categoría</label>
                    <select asp-for="CategoriaId" class="form-select">
                        @foreach (var cat in ViewBag.Categorias as List<UltraStock.Models.Categoria>)
                        {
                            <option value="@cat.Id" selected="@(cat.Id == Model.CategoriaId)">@cat.Nombre</option>
                        }
                    </select>
                </div>
            </div>
            <div class="mb-3">
                <label asp-for="ProveedorId" class="form-label fw-semibold">Proveedor</label>
                <select asp-for="ProveedorId" class="form-select">
                    @foreach (var prov in ViewBag.Proveedores as List<UltraStock.Models.Proveedor>)
                    {
                        <option value="@prov.Id" selected="@(prov.Id == Model.ProveedorId)">@prov.Nombre</option>
                    }
                </select>
            </div>
            <div class="mb-4">
                <label class="form-label fw-semibold">Nueva imagen (opcional)</label>
                @if (!string.IsNullOrEmpty(Model.ImagenUrl))
                {
                    <div class="mb-2">
                        <img src="@Model.ImagenUrl" width="80" height="80" style="object-fit:cover;border-radius:8px;" />
                        <span class="text-muted small ms-2">Imagen actual</span>
                    </div>
                }
                <input name="imagen" type="file" class="form-control" accept="image/*" />
            </div>
            <button type="submit" class="btn btn-primary px-4">Actualizar Producto</button>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

}
