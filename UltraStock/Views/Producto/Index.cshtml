@model List<UltraStock.Models.Producto>

<h2 class="mb-4 text-black center">Productos</h2>

@if (Context.Session.GetString("Rol") == "Administrador" || Context.Session.GetString("Rol") == "EncargadoAlmacen")
{
    <a class="btn btn-success mb-3" href="/Producto/Create">+ Nuevo Producto</a>
}

<div class="container mt-4">
    @if (TempData["Mensaje"] != null)
    {
        <div class="alert alert-success">
            @TempData["Mensaje"]
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">
            @TempData["Error"]
        </div>
    }

    <div class="row">
        @foreach (var item in Model)
        {
            <div class="col-md-3 mb-4">

                <div class="card h-100 shadow">

                    <img src="@(string.IsNullOrWhiteSpace(item.ImagenUrl) ? "/images/OIP.webp" : item.ImagenUrl)"
                         class="card-img-top"
                         style="height:200px; object-fit:cover;" />

                    <div class="card-body">

                        <h5 class="card-title">@item.Nombre</h5>

                        <p class="card-text">
                            Precio: $@item.Precio <br />
                            Stock: @item.Stock <br />
                            Categoria: @item.Categoria?.Nombre <br />
                            Proveedor: @item.Proveedor?.Nombre
                        </p>

                        @if (Context.Session.GetString("Rol") == "Administrador" || Context.Session.GetString("Rol") == "EncargadoAlmacen")
                        {
                            <a href="/Producto/Edit/@item.Id"
                               class="btn btn-warning btn-sm">Editar</a>
                        }

                        @if (Context.Session.GetString("Rol") == "Administrador")
                        {
                            <a href="/Producto/Delete/@item.Id"
                               class="btn btn-danger btn-sm">Eliminar</a>
                        }

                        @if (item.Stock == 0)
                        {
                            <div class="alert alert-warning text-center mt-3 mb-0">
                                Producto agotado
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
</div>
